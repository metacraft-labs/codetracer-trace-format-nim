ct-print.exe
ct-space.exe

# Glob catch-all for compiled Nim test/bench binaries in tests/ (replaces
# per-file maintenance burden; keep source files explicit via re-includes).
tests/test_*
!tests/test_*.nim
!tests/test_*.nims
!tests/test_*.sh
tests/bench_*
!tests/bench_*.nim
!tests/bench_*.nims

# Generated golden-test scratch outputs alongside committed goldens.
tests/goldens/*.actual

# Compiled ct-print binary built next to source.
src/codetracer_ct_print
# Macro sourcemap dumps generated by ct-print compile.
src/macro_sourcemap_*.json

# Nix-generated pre-commit config
.pre-commit-config.yaml

# reprobuild build artifacts
.repro/
# reprobuild build output tree (ct-print, per-test binaries, nimcache)
/build/
